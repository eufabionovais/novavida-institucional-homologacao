---
const {info, customClasses} = Astro.props;
import BaseButton from "./BaseButton.astro";
---

<div class="content-row" class:list={customClasses} data-animation="call-to-action">
  <div class="content-container">
    <div class="md:grid grid-cols-2 gap-4">
      <div class="call-to-action__image-wrapper">
          <img src={info.imagem.url} class="call-to-action__image" alt={info.imagem.alt}>
      </div>
      <div class="call-to-action__conteudo">
          <h3 class="call-to-action__titulo ">{info.titulo}</h3>
          {info.descricao &&
            <p class="call-to-action__descricao">{info.descricao}</p>            
          }

          <BaseButton variant="dark-outlined" classList={"mt-auto call-to-action__btn"}>Entre em Contato</BaseButton>
      </div>
    </div>
  </div>
</div>

<style>
  .call-to-action__image-wrapper {
    @apply  mb-5 md:mb-0 overflow-hidden;
    will-change: clip-path;
  }

  .call-to-action__image {
    @apply lg:max-w-full rounded-xl h-full object-cover w-full;
  }

  .call-to-action__conteudo {
    @apply px-4 pt-8 pb-8 lg:px-9 lg:pt-14 lg:pb-11 bg-primary rounded-xl text-black flex flex-col overflow-hidden;
    will-change: clip-path;
   
  }

  .call-to-action__titulo {
    @apply text-3xl font-regular leading-tight;
  }

  .call-to-action__descricao {
    @apply  text-base mt-4 leading-7;
  }
</style>