---
import IndicadoresNumericos from "./IndicadoresNumericos.astro"
---

<div class="content-row  text-white bg-black py-36 indicadores-wrapper">
  <div class="content-container lg:grid grid-cols-12">
    <div class="flex flex-col col-start-1 col-end-4">
        <h2 class="text-4xl font-light leading-tight">Uma empresa independente e inovadora</h2>

        <p class="mt-auto text-neutral">A Nova Vida TI transforma dados em soluções poderosas. Aqui está uma visão do nosso alcance:</p>

    </div>
    <div class="col-span-7  flex flex-wrap justify-center divide-y-2 lg:divide-y-0 divide-white  col-start-6 lg:grid gap-6 lg:grid-cols-7 lg:gap-y-52">
        <IndicadoresNumericos 
          numero="+2K"
          descricao="Clientes satisfeitos em todo o Brasil"
          classList={'text-white  lg:border-l border-white border-opacity-75 col-span-3 mb-6 pt-6'}
          data-animation='from-bottom'
        />

        <IndicadoresNumericos 
          numero="+1TB"
          descricao="De dados processados com precisão diária"
          classList={'text-white  lg:border-l border-white border-opacity-75 col-span-3 col-start-5 mb-6 pt-6'}
        /> 
        
        <IndicadoresNumericos 
          numero="+50M"
          descricao="Autenticações seguras todos os meses"
          classList={'text-white  lg:border-l border-white border-opacity-75 col-span-3 col-start-1 row-start-2  mb-6 pt-6'}
        />    
        
        <IndicadoresNumericos 
          numero="+9"
          descricao="Anos de experiência no mercado de dados"
          classList={'text-white  lg:border-l border-white border-opacity-75 col-span-3 col-start-5 row-start-2 pt-6'}
        />            

    </div>
  </div>

</div>

<style>
  .indicadores-wrapper {
    background: url('/img/home/indicadores/bg-indicadores.webp') no-repeat center / cover;
  }
</style>